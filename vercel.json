{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "echo 'static'",
  "outputDirectory": "docs",
  "headers": [
    {
      "source": "/data/map/(.*\\.json)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=86400"
        }
      ]
    }
  ]
}
